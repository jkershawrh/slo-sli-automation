{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "drift-report.schema.json",
  "title": "Drift Report",
  "description": "LLM-generated drift classification and remediation recommendations",
  "type": "object",
  "required": ["schema_version", "service", "classification", "severity", "likely_cause", "recommendations"],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "service": { "type": "string", "minLength": 1 },
    "classification": {
      "type": "string",
      "enum": [
        "latency_regression", "latency_improvement",
        "error_rate_elevation", "error_rate_reduction",
        "throughput_collapse", "throughput_surge",
        "saturation_approach", "availability_drop",
        "distribution_shift", "no_significant_drift"
      ]
    },
    "severity": {
      "type": "string",
      "enum": ["critical", "high", "medium", "low", "info"]
    },
    "likely_cause": { "type": "string", "minLength": 1 },
    "recommendations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["action", "confidence", "rationale"],
        "properties": {
          "action": { "type": "string", "minLength": 1 },
          "confidence": { "type": "string", "enum": ["high", "medium", "low"] },
          "rationale": { "type": "string", "minLength": 1 },
          "remediation_plan": {
            "type": "object",
            "properties": {
              "priority": { "type": "string", "enum": ["immediate", "short_term", "long_term"] },
              "evidence_basis": { "type": "string", "minLength": 1 },
              "expected_impact": { "type": "string", "minLength": 1 },
              "verification_method": { "type": "string", "minLength": 1 }
            },
            "description": "Structured remediation plan for negative drift"
          }
        }
      }
    }
  },
  "additionalProperties": false
}
