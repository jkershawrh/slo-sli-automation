{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "evidence.schema.json",
  "title": "Evidence Bundle",
  "description": "Raw telemetry evidence from Prometheus for baseline computation",
  "type": "object",
  "required": ["schema_version", "service", "namespace", "lookback_window", "collected_at", "coverage_ratio", "series", "provenance"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1, "maximum": 2 },
    "service": { "type": "string", "minLength": 1 },
    "namespace": { "type": "string", "minLength": 1 },
    "lookback_window": { "type": "string", "pattern": "^[0-9]+[smhd]$" },
    "collected_at": { "type": "string", "format": "date-time" },
    "coverage_ratio": { "type": "number", "minimum": 0, "maximum": 1 },
    "series": {
      "type": "object",
      "properties": {
        "latency_histogram": {
          "type": "object",
          "required": ["metric_name", "buckets"],
          "properties": {
            "metric_name": { "type": "string" },
            "buckets": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["le", "count"],
                "properties": {
                  "le": { "oneOf": [{ "type": "number" }, { "type": "string", "const": "+Inf" }] },
                  "count": { "type": "number", "minimum": 0 }
                }
              }
            },
            "total_count": { "type": "number", "minimum": 0 },
            "sum": { "type": "number", "minimum": 0 }
          }
        },
        "request_total": {
          "type": "object",
          "required": ["metric_name", "total"],
          "properties": {
            "metric_name": { "type": "string" },
            "total": { "type": "number", "minimum": 0 },
            "rate_samples": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["timestamp", "value"],
                "properties": {
                  "timestamp": { "type": "string", "format": "date-time" },
                  "value": { "type": "number", "minimum": 0 }
                }
              }
            }
          }
        },
        "error_total": {
          "type": "object",
          "required": ["metric_name", "total"],
          "properties": {
            "metric_name": { "type": "string" },
            "total": { "type": "number", "minimum": 0 }
          }
        },
        "saturation": {
          "type": "object",
          "properties": {
            "cpu": {
              "type": "object",
              "properties": {
                "metric_name": { "type": "string" },
                "samples": { "type": "array", "items": { "type": "number" } }
              }
            },
            "memory": {
              "type": "object",
              "properties": {
                "metric_name": { "type": "string" },
                "samples": { "type": "array", "items": { "type": "number" } }
              }
            },
            "available": { "type": "boolean" }
          }
        },
        "traces": {
          "type": "object",
          "properties": {
            "available": { "type": "boolean" },
            "source": { "type": "string" },
            "total_spans": { "type": "integer", "minimum": 0 },
            "service_spans": { "type": "integer", "minimum": 0 },
            "span_latency_p99_ms": { "type": "number", "minimum": 0 },
            "span_latency_p50_ms": { "type": "number", "minimum": 0 },
            "top_dependencies": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["service", "p99_ms", "call_count"],
                "properties": {
                  "service": { "type": "string" },
                  "p99_ms": { "type": "number", "minimum": 0 },
                  "call_count": { "type": "integer", "minimum": 0 },
                  "error_rate": { "type": "number", "minimum": 0, "maximum": 1 }
                }
              }
            },
            "slow_span_pattern": { "type": "string" }
          }
        },
        "logs": {
          "type": "object",
          "properties": {
            "available": { "type": "boolean" },
            "source": { "type": "string" },
            "total_entries": { "type": "integer", "minimum": 0 },
            "error_entries": { "type": "integer", "minimum": 0 },
            "error_breakdown": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["category", "count", "ratio"],
                "properties": {
                  "category": { "type": "string" },
                  "count": { "type": "integer", "minimum": 0 },
                  "ratio": { "type": "number", "minimum": 0, "maximum": 1 }
                }
              }
            },
            "error_rate_by_category": {
              "type": "object",
              "additionalProperties": { "type": "number" }
            }
          }
        }
      },
      "required": ["latency_histogram", "request_total", "error_total"]
    },
    "provenance": {
      "type": "object",
      "required": ["prometheus_endpoint", "query_timestamps", "queries"],
      "properties": {
        "prometheus_endpoint": { "type": "string", "format": "uri" },
        "query_timestamps": {
          "type": "object",
          "required": ["start", "end"],
          "properties": {
            "start": { "type": "string", "format": "date-time" },
            "end": { "type": "string", "format": "date-time" }
          }
        },
        "queries": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    }
  },
  "additionalProperties": false
}
